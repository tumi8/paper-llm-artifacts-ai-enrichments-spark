cd src && test -f libluajit.so && \
  install -m 0755 libluajit.so /root/libmoon/deps/luajit/usr/local/lib/libluajit-5.1.so.2.1.0 && \
  ldconfig -n /root/libmoon/deps/luajit/usr/local/lib && \
