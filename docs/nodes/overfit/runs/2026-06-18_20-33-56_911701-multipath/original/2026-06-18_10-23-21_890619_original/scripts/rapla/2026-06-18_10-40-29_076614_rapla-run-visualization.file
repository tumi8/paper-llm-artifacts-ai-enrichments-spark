#!/bin/bash
set -eux

RESULTS_DIR=$(pos_get_variable results_dir -r)

cd /root/masque-vis
source .venv/bin/activate
shopt -s nullglob
for path_dir in "$RESULTS_DIR"/*; do
    if [ ! -d "$path_dir" ]; then
        continue
    fi

    echo "Plotting results in $path_dir"
    python3 plot.py --results-dir "$path_dir"
done
deactivate
