++ pos_get_variable prefix_length -r
+ PREFIX_LENGTH=112
++ pos_get_variable client_ip -r
+ CLIENT_IP=fd00:0:0:1::1
++ pos_get_variable client_extra_ip -r
+ CLIENT_EXTRA_IP=fd00:0:0:2::1
++ pos_get_variable server_ip -r
+ SERVER_IP=fd00:0:0:4::1
++ pos_get_variable proxy_ip -r
+ PROXY_IP=fd00:0:0:3::1
++ pos_get_variable proxy_to_client_interface -r
+ PROXY_TO_CLIENT_INTERFACE=enp130s0f1
++ pos_get_variable proxy_to_client_extra_interface -r
+ PROXY_TO_CLIENT_EXTRA_INTERFACE=enp133s0f0
++ pos_get_variable proxy_to_server_interface -r
+ PROXY_TO_SERVER_INTERFACE=enp130s0f0
++ pos_get_variable fast_path_rate -r
+ FAST_PATH_RATE=50
++ pos_get_variable fast_path_delay -r
+ FAST_PATH_DELAY=2.5
++ pos_get_variable tbf_latency -r
+ TBF_LATENCY=10
++ pos_get_variable tbf_burst -r
+ TBF_BURST=64000
++ pos_get_variable proxy_server_delay -r
+ PROXY_TO_SERVER_DELAY=5
+ echo 'Configuring the proxy network'
+ sysctl -w net.ipv6.conf.all.forwarding=0
+ echo '...Set IFs up'
+ ip link set dev enp130s0f1 up
+ ip link set dev enp133s0f0 up
+ ip link set dev enp130s0f0 up
+ echo '...Assign per-link addresses'
+ ip addr add dev enp130s0f1 fd00:0:0:3::1/112
+ ip addr add dev enp133s0f0 fd00:0:0:3::1/112
+ ip addr add dev enp130s0f0 fd00:0:0:3::1/112
+ echo '...Add client routes'
+ ip -6 route add fd00:0:0:1::1/112 dev enp130s0f1
+ ip -6 route add fd00:0:0:2::1/112 dev enp133s0f0
+ echo '...Add server route'
+ ip -6 route add fd00:0:0:4::1/112 dev enp130s0f0
+ echo '...Set fixed path parameters'
+ tc qdisc replace dev enp130s0f1 root handle 1: tbf rate 50mbit latency 10ms burst 64000
+ tc qdisc replace dev enp130s0f1 parent 1: handle 10: netem delay 2.5ms
+ tc qdisc add dev enp130s0f0 root netem delay 5ms
